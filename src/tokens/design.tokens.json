      "10": { "$value": "#1d192b" },
      "20": { "$value": "#332d41" },
      "30": { "$value": "#4a4458" },
      "40": { "$value": "#625b71" },
      "50": { "$value": "#7a7289" },
      "60": { "$value": "#958da5" },
