{
  "$description": "kanso-ui design tokens. Conforms to the Design Tokens Community Group format (https://design-tokens.github.io/community-group/format/): $type/$value, group-level type inheritance, {path} alias references. Color roles, type scale, shape scale, elevation, and state-layer opacities are drawn from a verified tonal-palette color system, not approximations. Generated into StyleX via scripts/build-tokens.mjs (npm run tokens:build) — see src/tokens/*.stylex.ts.",
  "color": {
    "$type": "color",
    "$description": "Reference tier — the full tonal palettes. Not consumed directly by components — see semantic.light / semantic.dark, the System tier that maps roles onto specific tones. Each chromatic palette (primary/secondary/tertiary/error) holds all 13 standard tone stops; neutral additionally carries the extra surface-container stops (4/6/12/17/20/22/24/87/92/94/96/98/99).",
    "primary": {
      "$description": "Brand hue (violet) — a verified reference baseline seed (#6750a4), used verbatim.",
      "0": { "$value": "#000000" },
      "10": { "$value": "#21005d" },
      "20": { "$value": "#381e72" },
      "30": { "$value": "#4f378b" },
      "40": { "$value": "#6750a4" },
      "50": { "$value": "#7f67be" },
      "60": { "$value": "#9a82db" },
      "70": { "$value": "#b69df8" },
      "80": { "$value": "#d0bcff" },
