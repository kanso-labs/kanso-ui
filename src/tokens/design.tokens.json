  "elevation": {
    "$type": "number",
    "$description": "Elevation levels, expressed in dp. Informational — see shadow.* below for the actual box-shadow each level renders as.",
    "level0": { "$value": 0 },
    "level1": { "$value": 1 },
    "level2": { "$value": 3 },
    "level3": { "$value": 6 },
    "level4": { "$value": 8 },
    "level5": { "$value": 12 }
  },
  "shadow": {
    "$type": "shadow",
    "$description": "Elevation shadows are theme-invariant (always rendered in a fixed black — elevation is instead conveyed in dark mode via the surface-container tones above). Two-layer key+ambient formula, with verified per-level offset/blur/spread. No level0 entry — level0 renders no shadow.",
    "1": {
      "$value": [
        {
          "color": "rgba(0, 0, 0, 0.3)",
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "2px",
          "spread": "0px"
