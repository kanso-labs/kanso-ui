  "typography": {
    "fontFamily": {
      "$type": "fontFamily",
      "$description": "Two typeface roles: 'brand' (expressive, used by display/headline/title) and 'plain' (neutral, used by body/label). 'mono' is a kanso-specific extension for numeric/code display, outside the base scale.",
      "brand": {
        "$value": ["Roboto Serif", "Iowan Old Style", "Georgia", "serif"]
      },
      "mono": {
        "$value": [
          "Roboto Mono",
          "ui-monospace",
          "SF Mono",
          "Menlo",
          "monospace"
        ]
      },
      "plain": {
        "$value": [
          "Roboto Flex",
          "-apple-system",
          "BlinkMacSystemFont",
          "Segoe UI",
          "Roboto",
          "sans-serif"
        ]
      }
    },
    "fontWeight": {
      "$type": "fontWeight",
      "bold": { "$value": 700 },
      "medium": { "$value": 500 },
      "regular": { "$value": 400 }
    },
    "scale": {
      "$description": "The full 15-style type scale — display/headline/title/body/label, each in large/medium/small. Sizes are px, converted from a verified rem-based scale at a 16px root. `font` names which typeface role (brand/plain) each style uses.",
      "displayLarge": {
        "font": { "$value": "{typography.fontFamily.brand}" },
        "size": { "$type": "dimension", "$value": "57px" },
        "lineHeight": { "$type": "dimension", "$value": "64px" },
        "tracking": { "$type": "dimension", "$value": "-0.25px" },
        "weight": { "$value": "{typography.fontWeight.regular}" }
      },
      "displayMedium": {
        "font": { "$value": "{typography.fontFamily.brand}" },
        "size": { "$type": "dimension", "$value": "45px" },
        "lineHeight": { "$type": "dimension", "$value": "52px" },
