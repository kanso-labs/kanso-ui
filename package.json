{
  "name": "kanso-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "module": "./dist/index.js",
  "main": "./dist/cjs/index.cjs",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "tsc -b && tsdown",
    "build-storybook": "storybook build",
    "chromatic": "npx chromatic",
    "clean": "rimraf dist",
    "dev": "npm run storybook",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint . && eslint . && npm run format:check",
    "prepare": "husky && playwright install --with-deps",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@chromatic-com/storybook": "5.2.1",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@eslint/js": "10.0.1",
    "@rolldown/plugin-babel": "0.2.3",
    "@storybook/addon-a11y": "10.5.2",
    "@storybook/addon-docs": "10.5.2",
    "@storybook/addon-vitest": "10.5.2",
    "@storybook/builder-vite": "10.5.2",
    "@storybook/react-vite": "10.5.2",
    "@stylexjs/unplugin": "0.19.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.7.0",
    "eslint-plugin-oxlint": "1.73.0",
    "eslint-plugin-perfectionist": "5.10.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-storybook": "10.5.2",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxfmt": "0.59.0",
    "oxlint": "1.73.0",
    "playwright": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "rimraf": "6.1.3",
    "storybook": "10.5.2",
    "storybook-dark-mode": "5.0.0",
    "tsdown": "0.22.9",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
